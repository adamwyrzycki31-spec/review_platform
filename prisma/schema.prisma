// Prisma Schema for myprotector.org Trust & Review Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  INDIVIDUAL
  BUSINESS
  RESELLER
  SUPPORT
  ADMIN
}

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum TrafficLightStatus {
  RED
  AMBER
  GREEN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum Recommendation {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

enum BlacklistStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
}

enum WidgetType {
  BADGE
  CAROUSEL
  SCORE
  COMPACT
}

enum FileType {
  PDF
  IMAGE
}

enum TransactionType {
  SUBSCRIPTION
  COMMISSION
  REFUND
}

// User Model
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(INDIVIDUAL)
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  avatarUrl     String?   @map("avatar_url")
  emailVerified DateTime? @map("email_verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  business           Business?
  reseller           Reseller?
  reviews            Review[]         @relation("UserReviews")
  reviewImages       ReviewImage[]
  blacklistsReported Blacklist[]      @relation("BlacklistReporter")
  evidenceUploads    EvidenceUpload[]
  supportTickets     SupportTicket[]  @relation("UserTickets")
  assignedTickets    SupportTicket[]  @relation("AssignedTickets")
  reports            Report[]
  trafficSignals     TrafficSignal[]
  ticketMessages     TicketMessage[]

  @@map("users")
}

// Business Model
model Business {
  id                    String             @id @default(uuid())
  userId                String             @unique @map("user_id")
  name                  String
  slug                  String             @unique
  description           String?
  website               String?
  logoUrl               String?            @map("logo_url")
  coverImageUrl         String?            @map("cover_image_url")
  address               String?
  city                  String?
  country               String?
  phone                 String?
  businessEmail         String?            @map("business_email")
  categoryId            String?            @map("category_id")
  trustScore            Decimal            @default(0) @map("trust_score") @db.Decimal(3, 2)
  reviewCount           Int                @default(0) @map("review_count")
  subscriptionTier      SubscriptionTier   @default(FREE) @map("subscription_tier")
  subscriptionStatus    SubscriptionStatus @default(EXPIRED) @map("subscription_status")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  trafficLightStatus    TrafficLightStatus @default(RED) @map("traffic_light_status")
  insuranceUrl          String?            @map("insurance_url")
  termsUrl              String?            @map("terms_url")
  promisePageUrl        String?            @map("promise_page_url")
  claimPageUrl          String?            @map("claim_page_url")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  verifiedAt            DateTime?          @map("verified_at")

  // Relations
  user               User                @relation(fields: [userId], references: [id])
  category           Category?           @relation(fields: [categoryId], references: [id])
  reviews            Review[]
  trafficSignal      TrafficSignal?
  blacklists         Blacklist[]
  evidenceUploads    EvidenceUpload[]
  commissions        Commission[]
  widgets            Widget[]
  supportTickets     SupportTicket[]
  stripeSubscription StripeSubscription?
  transactions       Transaction[]

  @@map("businesses")
}

// Category Model
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  parentId    String?  @map("parent_id")
  reviewCount Int      @default(0) @map("review_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Self-relation for subcategories
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  // Relations
  businesses Business[]

  @@map("categories")
}

// Review Model
model Review {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  businessId       String         @map("business_id")
  rating           Int
  title            String
  content          String
  pros             String?
  cons             String?
  recommendation   Recommendation @default(POSITIVE)
  status           ReviewStatus   @default(PENDING)
  verifiedPurchase Boolean        @default(false) @map("verified_purchase")
  helpfulCount     Int            @default(0) @map("helpful_count")
  reportCount      Int            @default(0) @map("report_count")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  publishedAt      DateTime?      @map("published_at")

  // Relations
  user     User          @relation("UserReviews", fields: [userId], references: [id])
  business Business      @relation(fields: [businessId], references: [id])
  images   ReviewImage[]
  reports  Report[]

  @@map("reviews")
}

// Review Image Model
model ReviewImage {
  id           String   @id @default(uuid())
  reviewId     String   @map("review_id")
  url          String
  cloudinaryId String?  @map("cloudinary_id")
  caption      String?
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  review Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@map("review_images")
}

// Traffic Signal Model (Trust Verification)
model TrafficSignal {
  id                    String    @id @default(uuid())
  businessId            String    @unique @map("business_id")
  hasInsurance          Boolean   @default(false) @map("has_insurance")
  hasRefundPromise      Boolean   @default(false) @map("has_refund_promise")
  hasClaimPage          Boolean   @default(false) @map("has_claim_page")
  hasTermsClauses       Boolean   @default(false) @map("has_terms_clauses")
  hasActiveSubscription Boolean   @default(false) @map("has_active_subscription")
  verifiedAt            DateTime? @map("verified_at")
  expiresAt             DateTime? @map("expires_at")
  verifiedById          String?   @map("verified_by_id")
  notes                 String?

  // Relations
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  verifiedBy User?    @relation(fields: [verifiedById], references: [id])

  @@map("traffic_signals")
}

// Blacklist Model
model Blacklist {
  id           String          @id @default(uuid())
  businessId   String          @map("business_id")
  reporterId   String          @map("reporter_id")
  reason       String
  evidenceUrls Json?           @map("evidence_urls")
  status       BlacklistStatus @default(PENDING)
  adminNotes   String?         @map("admin_notes")
  createdAt    DateTime        @default(now()) @map("created_at")
  resolvedAt   DateTime?       @map("resolved_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id])
  reporter User     @relation("BlacklistReporter", fields: [reporterId], references: [id])

  @@map("blacklists")
}

// Evidence Upload Model
model EvidenceUpload {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  businessId   String   @map("business_id")
  fileUrl      String   @map("file_url")
  cloudinaryId String?  @map("cloudinary_id")
  fileType     FileType @map("file_type")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@map("evidence_uploads")
}

// Reseller Model
model Reseller {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  referralCode    String   @unique @map("referral_code")
  commissionRate  Decimal  @default(0.1) @map("commission_rate") @db.Decimal(5, 2)
  totalCommission Decimal  @default(0) @map("total_commission") @db.Decimal(10, 2)
  paidCommission  Decimal  @default(0) @map("paid_commission") @db.Decimal(10, 2)
  clientCount     Int      @default(0) @map("client_count")
  stripeAccountId String?  @map("stripe_account_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id])
  commissions  Commission[]
  transactions Transaction[]

  @@map("resellers")
}

// Commission Model
model Commission {
  id          String           @id @default(uuid())
  resellerId  String           @map("reseller_id")
  businessId  String           @map("business_id")
  amount      Decimal          @db.Decimal(10, 2)
  status      CommissionStatus @default(PENDING)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  paidAt      DateTime?        @map("paid_at")

  // Relations
  reseller Reseller @relation(fields: [resellerId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@map("commissions")
}

// Widget Model
model Widget {
  id         String     @id @default(uuid())
  businessId String     @map("business_id")
  type       WidgetType
  name       String
  config     Json
  embedCode  String     @map("embed_code")
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("widgets")
}

// Email Template Model
model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  subject   String
  body      String   @db.Text
  variables Json?    @map("variables")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sends EmailSend[]

  @@map("email_templates")
}

// Email Send Log
model EmailSend {
  id             String   @id @default(uuid())
  templateId     String?  @map("template_id")
  recipientEmail String   @map("recipient_email")
  recipientName  String?  @map("recipient_name")
  subject        String
  status         String // sent, delivered, bounced, failed
  errorMessage   String?  @map("error_message")
  sentAt         DateTime @default(now()) @map("sent_at")

  // Relations
  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@map("email_sends")
}

// Support Ticket Model
model SupportTicket {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  businessId String?        @map("business_id")
  subject    String
  content    String         @db.Text
  status     TicketStatus   @default(OPEN)
  priority   TicketPriority @default(MEDIUM)
  assignedTo String?        @map("assigned_to")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  // Relations
  user     User            @relation("UserTickets", fields: [userId], references: [id])
  business Business?       @relation(fields: [businessId], references: [id])
  assignee User?           @relation("AssignedTickets", fields: [assignedTo], references: [id])
  messages TicketMessage[]

  @@map("support_tickets")
}

// Ticket Message Model
model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  userId     String   @map("user_id")
  content    String   @db.Text
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@map("ticket_messages")
}

// Report Model
model Report {
  id          String       @id @default(uuid())
  reviewId    String       @map("review_id")
  reporterId  String       @map("reporter_id")
  reason      String
  description String?
  status      ReportStatus @default(PENDING)
  adminNotes  String?      @map("admin_notes")
  createdAt   DateTime     @default(now()) @map("created_at")
  resolvedAt  DateTime?    @map("resolved_at")

  // Relations
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id])

  @@map("reports")
}

// Page SEO Model
model PageSeo {
  id              String   @id @default(uuid())
  pagePath        String   @unique @map("page_path")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  ogTitle         String?  @map("og_title")
  ogDescription   String?  @map("og_description")
  ogImage         String?  @map("og_image")
  canonicalUrl    String?  @map("canonical_url")
  robots          Json?    @map("robots")
  schemaMarkup    Json?    @map("schema_markup")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("page_seo")
}

// Stripe Subscription Model (for tracking payments)
model StripeSubscription {
  id                   String   @id @default(uuid())
  businessId           String   @unique @map("business_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  stripeCustomerId     String   @map("stripe_customer_id")
  status               String
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("stripe_subscriptions")
}

// Transaction Log Model
model Transaction {
  id          String          @id @default(uuid())
  businessId  String?         @map("business_id")
  resellerId  String?         @map("reseller_id")
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD")
  description String?
  stripeId    String?         @map("stripe_id")
  status      String          @default("completed")
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  // Relations
  business Business? @relation(fields: [businessId], references: [id])
  reseller Reseller? @relation(fields: [resellerId], references: [id])

  @@map("transactions")
}
